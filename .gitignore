# Dependencies
node_modules/
.npm-cache/
# pnpm content-addressable store (created when running in sandbox mode)
.pnpm-store/
# Build output
dist/

# Local data & auth
store/
data/
logs/

# Generated by scripts/class-skeleton.ts at provisioning time. Operator-
# specific (pairing codes, real student names) — must not be checked in.
/class-roster.csv

# Groups - per-installation state, not tracked
groups/*

# Composer-managed CLAUDE.md artifacts (regenerated every spawn) and
# per-group memory (CLAUDE.local.md) must never be committed.
**/CLAUDE.local.md
**/.claude-shared.md
**/.claude-fragments/

# Secrets
*.keys.json
.env
.env*

# Temp files
.tmp-*

# OS
.DS_Store

# IDE
.idea/
.vscode/

# Skills system (local per-installation state)
.nanoclaw/

agents-sdk-docs

# /add-admintools — locally-installed admin tools (copied from `admin` branch).
# Only the Telegram-command surface (handlers + auth-mode switch + interactive
# script) is opt-in. The model-discovery / model-switch / model-providers
# helpers are imported by trunk's playground Models tab API and ship in trunk.
src/admin-handlers/auth.ts
src/admin-handlers/model.ts
src/admin-handlers/provider.ts
src/auth-switch.ts
scripts/switch-provider.ts

# Per-install classroom state (PII / install-specific) — regenerated by
# class-skeleton.ts on each run, and the controls config is locally-tuned.
class-roster.csv
config/class-controls.json
